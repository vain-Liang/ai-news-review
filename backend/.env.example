APP_NAME="AI News Overview"
DEBUG=true
# Logging: level is one of DEBUG, INFO, WARNING, ERROR; format is "text" or "json"
LOG_LEVEL="INFO"
LOG_FORMAT="text"

# Database
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD="yourpassword"
POSTGRES_DB=ai_news_overview

# Security
# JWT secret, reset_password_token_secret, verification_token_secret
AUTH_SECRET="very-strong-secret-key"
FRONTEND_BASE_URL="http://127.0.0.1:5173"
ADMIN_API_PREFIX="/admin/"

# Mail / SMTP
MAIL_ENABLED=false
MAIL_SENDER_EMAIL="noreply@example.com"
MAIL_SENDER_NAME="AI News Overview"
SMTP_HOST=""
SMTP_PORT=587
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_VALIDATE_CERTS=true
SMTP_TIMEOUT_SECONDS=10
EMAIL_RATE_LIMIT_TIMES=5
EMAIL_RATE_LIMIT_SECONDS=60

# Third-party provider examples:
# Gmail / Google Workspace:
# SMTP_HOST="smtp.gmail.com" SMTP_PORT=587 SMTP_USE_TLS=true SMTP_USE_SSL=false
# QQ Mail:
# SMTP_HOST="smtp.qq.com" SMTP_PORT=465 SMTP_USE_TLS=false SMTP_USE_SSL=true
# 163 Mail:
# SMTP_HOST="smtp.163.com" SMTP_PORT=465 SMTP_USE_TLS=false SMTP_USE_SSL=true
# Outlook / Microsoft 365:
# SMTP_HOST="smtp.office365.com" SMTP_PORT=587 SMTP_USE_TLS=true SMTP_USE_SSL=false
# Usually you need an app password or SMTP authorization code instead of your login password.

# Cookie configuration
# https://fastapi-users.github.io/fastapi-users/latest/configuration/authentication/transports/cookie/
# Name of the cookie
COOKIE_NAME="fastapiusersauth"
# The lifetime of the cookie in seconds
COOKIE_MAX_AGE=3600
# Cookie path
COOKIE_PATH=/
# Cookie domain
COOKIE_DOMAIN=
# Whether to only send the cookie to the server via SSL request
# set false for debug or dev only
COOKIE_SECURE=false
# Whether to prevent access to the cookie via JavaScript
COOKIE_HTTPONLY=false
#  A string that specifies the samesite strategy for the cookie. Valid values are `lax`, `strict` and `none`
# Defaults to `lax`
COOKIE_SAMESITE=lax

# The lifetime of the token in seconds
TOKEN_LIFETIME_SECONDS=3600

CORS_ORIGINS="http://127.0.0.1:5173,http://localhost:5173"

# Celery (RabbitMQ broker + Redis result backend)
CELERY_BROKER_URL="amqp://guest:guest@localhost:5672//"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# Redis (used for pipeline rate limiting; can point to the same instance as Celery)
REDIS_URL="redis://localhost:6379/0"

# Per-user manual trigger limits (applied separately to /retrieve and /summarize)
PIPELINE_DAILY_LIMIT=2
PIPELINE_MIN_INTERVAL_SECONDS=3600

# Chroma vector store
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=news_articles

# LangChain LLM provider selection
LLM_PROVIDER="deepseek"

# DeepSeek / LangChain RAG
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_TEMPERATURE=0.2
DEEPSEEK_MAX_COMPLETION_TOKENS=1200

# OpenAI / LangChain RAG
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_COMPLETION_TOKENS=1200
