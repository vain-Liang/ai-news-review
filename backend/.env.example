APP_NAME="AI News Overview"
DEBUG=true

# Database
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD="yourpassword"
POSTGRES_DB=ai_news_overview

# Security
# JWT secret, reset_password_token_secret, verification_token_secret
AUTH_SECRET="very-strong-secret-key"

# Cookie configuration
# https://fastapi-users.github.io/fastapi-users/latest/configuration/authentication/transports/cookie/
# Name of the cookie
COOKIE_NAME="fastapiusersauth"
# The lifetime of the cookie in seconds
COOKIE_MAX_AGE=3600
# Cookie path
COOKIE_PATH=/
# Cookie domain
COOKIE_DOMAIN=
# Whether to only send the cookie to the server via SSL request
# set false for debug or dev only
COOKIE_SECURE=false
# Whether to prevent access to the cookie via JavaScript
COOKIE_HTTPONLY=false
#  A string that specifies the samesite strategy for the cookie. Valid values are `lax`, `strict` and `none`
# Defaults to `lax`
COOKIE_SAMESITE=lax

# The lifetime of the token in seconds
TOKEN_LIFETIME_SECONDS=3600

CORS_ORIGINS="http://127.0.0.1:5173,http://localhost:5173"
