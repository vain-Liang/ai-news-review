# top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ===== Python (backend) =====
[*.py]
indent_style = space
indent_size = 4
max_line_length = 120

# avoid conflicts with Ruff
trim_trailing_whitespace = true

# ===== Frontend (JS/TS/React) =====
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2
max_line_length = 100

# ===== JSON =====
[*.json]
indent_style = space
indent_size = 2

# ===== YAML =====
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# ===== Markdown =====
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ===== Shell scripts =====
[*.sh]
indent_style = space
indent_size = 2

# ===== Config files =====
[*.{toml,ini}]
indent_style = space
indent_size = 2

# ===== Makefile =====
[Makefile]
indent_style = tab