{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: install",
      "type": "shell",
      "command": "uv sync",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "backend: dev",
      "type": "shell",
      "command": "uv run fastapi dev src/app/main.py --host 127.0.0.1 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": ".*(Uvicorn running on|Server started at|Application startup complete).*"
        }
      }
    },
    {
      "label": "backend: test",
      "type": "shell",
      "command": "uv run pytest",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "backend: lint",
      "type": "shell",
      "command": "uv run ruff check . && uv run ty check",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "frontend: install",
      "type": "shell",
      "command": "pnpm install",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "frontend: dev",
      "type": "shell",
      "command": "pnpm dev --host 127.0.0.1 --port 5173",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": ".*(Local:|ready in|http://127\\.0\\.0\\.1:5173|http://localhost:5173).*"
        }
      }
    },
    {
      "label": "frontend: build",
      "type": "shell",
      "command": "pnpm build",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "frontend: lint",
      "type": "shell",
      "command": "pnpm lint",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "frontend: test",
      "type": "shell",
      "command": "pnpm test",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "dev: install all",
      "dependsOrder": "sequence",
      "dependsOn": [
        "backend: install",
        "frontend: install"
      ],
      "problemMatcher": []
    },
    {
      "label": "dev: start all",
      "dependsOrder": "parallel",
      "dependsOn": [
        "backend: dev",
        "frontend: dev"
      ],
      "problemMatcher": []
    },
    {
      "label": "check: all",
      "dependsOrder": "sequence",
      "dependsOn": [
        "backend: lint",
        "backend: test",
        "frontend: lint",
        "frontend: test"
      ],
      "problemMatcher": []
    }
  ]
}